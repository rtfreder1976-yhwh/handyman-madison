---
import Layout from "../../layouts/Layout.astro";
import TrustCredentials from "../../components/TrustCredentials.astro";
import InlineQuoteForm from "../../components/InlineQuoteForm.astro";

const includedServices = [
  {
    title: "Epoxy Floor Coating",
    items: [
      "Single-coat solid epoxy application",
      "Multi-layer high-build epoxy systems",
      "Metallic epoxy designer floors",
      "Water-based and solvent-based epoxy options",
      "Anti-slip additive integration",
      "UV-resistant topcoat finishing",
      "Color-matched custom blends",
      "Industrial-strength commercial epoxy",
    ],
  },
  {
    title: "Flake (Chip) Floor Systems",
    items: [
      "Full-broadcast decorative flake floors",
      "Partial-broadcast accent flake designs",
      "Custom color flake blending",
      "Multi-color chip combinations",
      "Clear polyaspartic topcoat sealing",
      "Textured non-slip flake finishes",
      "Seamless one-day flake installations",
      "High-durability broadcast systems",
    ],
  },
  {
    title: "Surface Preparation",
    items: [
      "Diamond grinding and profiling",
      "Concrete crack and spall repair",
      "Moisture testing and vapor mitigation",
      "Oil stain and contaminant removal",
      "Expansion joint treatment",
      "Concrete leveling and patching",
      "Previous coating removal",
      "Acid etching when required",
    ],
  },
  {
    title: "Specialty Coatings",
    items: [
      "Polyaspartic fast-cure systems",
      "Polyurea high-performance coatings",
      "Chemical-resistant workshop floors",
      "Hot-tire pickup resistant finishes",
      "Garage workshop anti-fatigue coatings",
      "Showroom-grade mirror finishes",
      "Outdoor-rated patio and carport coatings",
      "Commercial warehouse floor systems",
    ],
  },
];

const coatingTypes = [
  {
    name: "Solid Epoxy",
    durability: "10-20 years",
    best: "Standard garages, workshops",
    cureTime: "3-5 days",
    maintenance: "Very low - sweep and mop",
  },
  {
    name: "Flake/Chip",
    durability: "15-20 years",
    best: "Residential garages, showrooms",
    cureTime: "1-2 days (polyaspartic)",
    maintenance: "Very low - sweep and mop",
  },
  {
    name: "Metallic Epoxy",
    durability: "15-20 years",
    best: "Showrooms, man caves, upscale garages",
    cureTime: "3-5 days",
    maintenance: "Low - sweep and damp mop",
  },
  {
    name: "Polyaspartic",
    durability: "15-25 years",
    best: "High-traffic, fast turnaround",
    cureTime: "1 day",
    maintenance: "Very low - sweep and mop",
  },
  {
    name: "Polyurea",
    durability: "20+ years",
    best: "Extreme environments, chemical exposure",
    cureTime: "1 day",
    maintenance: "Very low - virtually maintenance-free",
  },
];

const commonProblems = [
  {
    problem: "Cracked, pitting, or spalling concrete garage floor",
    solution:
      "We grind, fill, and seal every imperfection before applying your coating system. The result is a flawless, factory-smooth surface that stops further deterioration permanently.",
  },
  {
    problem: "Oil stains and chemical damage that won't clean up",
    solution:
      "Our diamond grinding process removes embedded oil and chemical damage down to clean concrete. Your new epoxy or flake coating creates an impenetrable barrier against future stains.",
  },
  {
    problem: "Dusty concrete that tracks grime into your home",
    solution:
      "Bare concrete constantly sheds microscopic dust. Our coating system seals the surface completely, eliminating concrete dust and making your garage as clean as any room in your house.",
  },
  {
    problem: "Slippery garage floor that's dangerous when wet",
    solution:
      "We integrate professional-grade anti-slip additives directly into your topcoat. Walk confidently on your garage floor in any weather condition, even with wet shoes or snow melt.",
  },
  {
    problem: "Previous DIY coating peeling and flaking off",
    solution:
      "We completely remove the failed coating, properly profile the concrete with diamond grinders, and apply a professional-grade system that bonds permanently. No peeling. No flaking. Guaranteed.",
  },
  {
    problem: "Hot tire pickup leaving marks on the floor",
    solution:
      "Our polyaspartic and polyurea topcoats are specifically engineered to resist hot-tire pickup. Your coated floor stays pristine no matter how hot your tires get after highway driving.",
  },
  {
    problem: "Damp, musty garage with moisture seeping through concrete",
    solution:
      "We perform professional moisture testing and apply vapor-mitigating primers before your coating. This stops moisture migration and transforms your damp garage into a dry, usable space.",
  },
  {
    problem: "Outdated, ugly garage floor dragging down home value",
    solution:
      "A professionally coated garage floor delivers one of the highest ROI upgrades for your home. Buyers notice immediately. Your garage transforms from eyesore to showpiece in a single day.",
  },
];

const processSteps = [
  {
    step: 1,
    title: "Free Consultation & Estimate",
    description:
      "Text us a photo of your garage floor or call for a free on-site assessment. We evaluate your concrete condition, discuss coating options, and lock in transparent pricing with zero hidden fees.",
    time: "Same day response",
  },
  {
    step: 2,
    title: "Concrete Assessment & Prep Plan",
    description:
      "We inspect for moisture issues, cracks, previous coatings, and contaminants. You receive a detailed prep-and-install plan tailored to your garage's exact condition and your performance requirements.",
    time: "Included in estimate visit",
  },
  {
    step: 3,
    title: "Diamond Grinding & Surface Prep",
    description:
      "Our industrial diamond grinders open the concrete pores for maximum coating adhesion. We fill cracks, repair spalls, and create the ideal surface profile. This step determines coating longevity.",
    time: "Day 1 morning",
  },
  {
    step: 4,
    title: "Primer & Base Coat Application",
    description:
      "We apply a penetrating primer that bonds deep into the concrete, followed by your chosen base coat color. Each layer is rolled at precise mil thickness for uniform coverage and maximum durability.",
    time: "Day 1 afternoon",
  },
  {
    step: 5,
    title: "Flake Broadcast or Design Layer",
    description:
      "For flake systems, we broadcast your chosen color blend at full coverage for a seamless look. For metallic or solid systems, we apply the design layer with professional technique for stunning results.",
    time: "Immediately after base coat",
  },
  {
    step: 6,
    title: "Topcoat & Protective Seal",
    description:
      "A high-performance clear topcoat locks everything in and provides UV protection, chemical resistance, and hot-tire pickup resistance. This layer is what makes your floor virtually indestructible.",
    time: "Day 2 (or same day for polyaspartic)",
  },
  {
    step: 7,
    title: "Quality Inspection & Walkthrough",
    description:
      "We conduct a thorough inspection of every square foot. You walk the finished floor with us to confirm complete satisfaction before we consider the job done. We leave your garage spotless.",
    time: "Final step",
  },
];

const faqs = [
  {
    question: "How much does garage floor coating cost?",
    answer:
      "Professional garage floor coating typically ranges from $3-$12 per square foot installed, depending on the system. A standard 2-car garage (400-500 sq ft) runs $1,500-$5,000. Solid epoxy is most affordable, flake systems are mid-range, and metallic or polyaspartic systems are premium. We provide free detailed estimates with no hidden costs.",
  },
  {
    question: "How long does garage floor coating take to install?",
    answer:
      "Polyaspartic and polyurea systems can be completed in a single day with vehicle parking in 24 hours. Traditional epoxy systems require 2-3 days of application time plus 3-5 days of cure time before heavy use. We schedule around your needs and clearly communicate the timeline upfront.",
  },
  {
    question: "How long do I need to keep my car off the new floor?",
    answer:
      "For polyaspartic systems, you can typically park on the floor within 24 hours. For epoxy systems, we recommend waiting 72 hours for light foot traffic and 5-7 days before parking vehicles. We provide exact timing based on your specific coating system and current temperature conditions.",
  },
  {
    question: "Will epoxy coating fix cracks in my garage floor?",
    answer:
      "We repair all cracks, spalls, and imperfections as part of our surface preparation process before applying any coating. Small cracks are filled with epoxy filler, and larger structural cracks are addressed with proper crack repair systems. The coating then seals and protects the repaired surface.",
  },
  {
    question: "What's the difference between epoxy and polyaspartic coatings?",
    answer:
      "Epoxy is more affordable and provides excellent chemical resistance but requires 3-5 days to fully cure. Polyaspartic costs more but cures in hours, offers superior UV stability (won't yellow), and resists hot-tire pickup better. We often recommend polyaspartic topcoats over epoxy base coats for the best of both worlds.",
  },
  {
    question: "Can you coat a floor with existing epoxy or paint on it?",
    answer:
      "Yes, but the old coating must be removed or properly abraded first. We use diamond grinders to remove or profile existing coatings down to clean, bondable concrete. Applying new coating over a failing old one guarantees failure. We do it right the first time.",
  },
  {
    question: "Are garage floor coatings slippery?",
    answer:
      "Not when installed properly. We incorporate professional anti-slip additives into the topcoat, and flake broadcast systems naturally create texture. Your coated floor will be safer than bare concrete, even when wet from rain, snow melt, or car wash runoff.",
  },
  {
    question: "Do you offer any warranty on garage floor coatings?",
    answer:
      "Yes. Our professional coating systems come with manufacturer warranties on materials, and we stand behind our workmanship. Specific warranty terms depend on the coating system selected. We discuss all warranty details during your free consultation so you know exactly what's covered.",
  },
  {
    question: "Can garage floor coating be applied in winter or cold weather?",
    answer:
      "Temperature matters. Most coatings require concrete and ambient temperatures above 50°F during application and cure. In North Alabama, we can install year-round in most conditions. If temperatures are too low, we'll schedule for the next appropriate window rather than risk a compromised installation.",
  },
  {
    question: "What makes your garage floor coating service different from DIY kits?",
    answer:
      "Professional diamond grinding creates 10x the adhesion profile of DIY acid etching. Our commercial-grade coatings are 3-5x thicker than retail kits. We use industrial equipment, proper moisture testing, and professional-grade materials that aren't available at home improvement stores. The result lasts 15-20 years instead of 2-3.",
  },
];

const serviceAreas = [
  { city: "Madison", driveTime: "Local", note: "Same-day available" },
  { city: "Huntsville", driveTime: "10-20 min", note: "Same-day available" },
  { city: "Decatur", driveTime: "25-35 min", note: "Serving this area" },
  { city: "Athens", driveTime: "20-30 min", note: "Serving this area" },
  { city: "Harvest", driveTime: "15-25 min", note: "Same-day available" },
  {
    city: "Owens Cross Roads",
    driveTime: "25-35 min",
    note: "Serving this area",
  },
  { city: "Hampton Cove", driveTime: "20-30 min", note: "Serving this area" },
  {
    city: "Redstone Arsenal",
    driveTime: "15-25 min",
    note: "Same-day available",
  },
];
---

<Layout
  title="Garage Floor Coating (Epoxy & Flake) | Madison AL"
  description="Professional garage floor coating in Madison, Huntsville & North Alabama. Epoxy, flake, polyaspartic & metallic systems. Transform your garage in one day. Free estimates."
>
  <!-- Premium Hero Section -->
  <section
    class="relative bg-blue-900 text-white pt-32 pb-24 flex items-center overflow-hidden"
  >
    <div class="absolute inset-0 z-0">
      <div
        class="w-full h-full bg-gradient-to-br from-blue-950 via-blue-900 to-blue-800"
      >
      </div>
      <div
        class="absolute inset-0 bg-gradient-to-t from-blue-950 via-blue-900/90 to-blue-900/60"
      >
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 relative z-10 w-full">
      <div class="max-w-3xl">
        <nav
          class="text-blue-200 text-sm mb-6 flex items-center gap-2 font-medium tracking-wide"
        >
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="opacity-50">/</span>
          <a href="/services" class="hover:text-white transition-colors"
            >Services</a
          >
          <span class="opacity-50">/</span>
          <span class="text-orange-400">Garage Floor Coating</span>
        </nav>

        <div
          class="inline-block px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 mb-6 text-sm font-medium text-blue-100"
        >
          <span
            class="w-2 h-2 inline-block rounded-full bg-orange-400 mr-2 animate-pulse"
          ></span>
          Premium Garage Transformations
        </div>

        <h1
          class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight tracking-tight"
        >
          Garage Floor <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-orange-600"
            >Coating</span
          >
        </h1>

        <p
          class="text-xl md:text-2xl text-blue-100 mb-10 font-light leading-relaxed"
        >
          Stop tolerating a cracked, stained concrete floor. Our professional epoxy and flake coating systems transform your garage into a showroom-quality space that resists everything you throw at it.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="sms:2562210373"
            class="group bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 text-lg flex items-center justify-center gap-3 shadow-lg shadow-orange-500/30 hover:shadow-orange-500/50 hover:-translate-y-1 border border-orange-400/30"
          >
            <svg
              class="w-6 h-6 group-hover:scale-110 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
              ></path>
            </svg>
            Text A Photo For Instant Quote
          </a>
        </div>
      </div>
    </div>

    <!-- Decorative shape divider -->
    <div
      class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-10"
    >
      <svg
        class="relative block w-full h-[50px] md:h-[100px]"
        data-name="Layer 1"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1200 120"
        preserveAspectRatio="none"
