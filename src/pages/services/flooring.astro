---
import Layout from "../../layouts/Layout.astro";
import TrustCredentials from "../../components/TrustCredentials.astro";
import InlineQuoteForm from "../../components/InlineQuoteForm.astro";

const includedServices = [
  {
    title: "Hardwood Flooring",
    items: [
      "Solid hardwood installation",
      "Engineered hardwood installation",
      "Hardwood floor refinishing",
      "Sand and stain services",
      "Plank replacement & matching",
      "Nail-down & glue-down methods",
      "Pre-finished hardwood",
      "Custom stain color matching",
    ],
  },
  {
    title: "Laminate & LVP",
    items: [
      "Luxury vinyl plank (LVP) installation",
      "Laminate flooring installation",
      "Waterproof LVP for kitchens & baths",
      "Floating floor systems",
      "Click-lock plank installation",
      "Transition strip installation",
      "Stair nose & threshold installation",
      "Pattern & diagonal layouts",
    ],
  },
  {
    title: "Subfloor & Prep Work",
    items: [
      "Subfloor inspection & repair",
      "Leveling with self-leveling compound",
      "Moisture barrier installation",
      "Underlayment installation",
      "Squeaky subfloor repair",
      "Damaged subfloor replacement",
      "Concrete subfloor prep",
      "Removal of old flooring",
    ],
  },
  {
    title: "Repairs & Touch-Ups",
    items: [
      "Hardwood plank replacement",
      "Water damage flooring repair",
      "Gap filling & board stabilization",
      "Scratch & gouge repair",
      "Cupping & buckling correction",
      "Squeaky floor elimination",
      "Threshold & transition repairs",
      "New flooring blending & matching",
    ],
  },
];

const flooringTypes = [
  {
    name: "Solid Hardwood",
    durability: "25-100+ years",
    best: "Living rooms, bedrooms, hallways",
    waterproof: "No",
    maintenance: "Refinish every 7-10 years",
  },
  {
    name: "Engineered Hardwood",
    durability: "20-40 years",
    best: "Basements, over concrete, kitchens",
    waterproof: "Moisture resistant",
    maintenance: "Low - sweep and damp mop",
  },
  {
    name: "Luxury Vinyl Plank (LVP)",
    durability: "15-25 years",
    best: "Kitchens, baths, high-traffic areas",
    waterproof: "100% waterproof",
    maintenance: "Very low - sweep and mop",
  },
  {
    name: "Laminate",
    durability: "15-25 years",
    best: "Bedrooms, living rooms, offices",
    waterproof: "Water resistant",
    maintenance: "Low - sweep and damp mop",
  },
  {
    name: "Engineered Hardwood",
    durability: "20-30 years",
    best: "Whole-home installs, over radiant heat",
    waterproof: "Moisture resistant",
    maintenance: "Low - vacuum and mop",
  },
];

const commonProblems = [
  {
    problem: "Squeaky, bouncy, or bouncy subfloor under existing flooring",
    solution:
      "We locate the problem joists, secure them with screws or blocking, and level the subfloor before installing new material. The result is a solid, silent floor.",
  },
  {
    problem: "Water-damaged hardwood that is cupped, buckled, or warped",
    solution:
      "We assess the extent of damage, dry the subfloor thoroughly, replace affected planks, and refinish to blend seamlessly with the existing floor.",
  },
  {
    problem: "Uneven or damaged subfloor left behind from previous flooring",
    solution:
      "We repair, fill, and level the subfloor surface with self-leveling compound so your new hardwood or LVP lays perfectly flat with no humps or dips.",
  },
  {
    problem: "Gaps between hardwood planks from seasonal movement",
    solution:
      "We fill, stabilize, or replace affected boards and advise on humidity control to prevent recurrence. Minor gaps can often be filled; larger separations require board replacement.",
  },
  {
    problem: "Scratched, dull, or worn hardwood floor surface",
    solution:
      "We sand down to raw wood, apply your chosen stain, and apply fresh polyurethane topcoats. Your floor looks brand new without the cost of full replacement.",
  },
  {
    problem: "LVP or laminate planks that are clicking, lifting, or separating",
    solution:
      "We identify the cause — moisture, subfloor imperfection, or inadequate expansion gap — and make the correct repair so the floor lies flat and stable.",
  },
];

const processSteps = [
  {
    step: 1,
    title: "Free Assessment & Material Selection",
    description:
      "We visit your home, assess the subfloor condition, measure the space, and walk you through flooring options that fit your style and budget. You'll leave with a clear, itemized quote.",
    time: "Same-day response",
  },
  {
    step: 2,
    title: "Subfloor Preparation",
    description:
      "We remove existing flooring, inspect the subfloor for damage, squeaks, and levelness. Any issues are corrected with screws, blocking, patching, or self-leveling compound before a single plank is laid.",
    time: "Day 1 morning",
  },
  {
    step: 3,
    title: "Moisture Barrier & Underlayment",
    description:
      "Depending on your flooring type and subfloor material, we install the appropriate moisture barrier and/or underlayment to prevent moisture migration and provide sound dampening.",
    time: "Day 1 afternoon",
  },
  {
    step: 4,
    title: "Flooring Installation",
    description:
      "We install your chosen flooring using the correct method — nail-down for solid hardwood, glue-down for engineered, or floating for LVP and laminate. Every plank is checked for fit, level, and finish.",
    time: "Day 1-2 depending on size",
  },
  {
    step: 5,
    title: "Trim, Transitions & Finishing",
    description:
      "We install all baseboards, quarter-round, threshold transitions, and stair noses. Every edge is caulked and touched up for a clean, professional finish throughout the space.",
    time: "Final day",
  },
  {
    step: 6,
    title: "Cleanup & Final Walkthrough",
    description:
      "We clean up all debris and dust, vacuum the new floor, and walk the finished space with you to confirm you're 100% satisfied. We don't leave until the job meets our standard.",
    time: "Final step",
  },
];

const faqs = [
  {
    question: "How much does hardwood flooring installation cost?",
    answer:
      "Hardwood flooring installation in North Alabama typically runs $6-$12 per square foot installed, depending on the species, grade, and room complexity. Engineered hardwood is $5-$10/sq ft and LVP is $3-$7/sq ft installed. We provide free, detailed estimates so you know exactly what to expect.",
  },
  {
    question: "What flooring is best for kitchens and bathrooms?",
    answer:
      "Luxury Vinyl Plank (LVP) is our top recommendation for kitchens and bathrooms. It's 100% waterproof, extremely durable underfoot, comes in hundreds of realistic wood looks, and is one of the most affordable options available. Engineered hardwood is also usable in kitchens but we don't recommend it for bathrooms.",
  },
  {
    question: "How long does flooring installation take?",
    answer:
      "A standard 400-800 sq ft room typically takes 1-2 days including subfloor prep. Larger whole-home installs may take 3-5 days. We give you a clear timeline during your estimate so you can plan accordingly.",
  },
  {
    question: "Do you move furniture during installation?",
    answer:
      "We ask that you clear the installation area of furniture before we arrive for large items. We can help move medium furniture as needed. We are not able to move electronics, large appliances, or antiques without liability coverage.",
  },
  {
    question: "How long should flooring acclimate before installation?",
    answer:
      "Solid hardwood should acclimate in the installation room for 3-5 days. Engineered hardwood needs 48-72 hours. LVP and laminate typically require 24-48 hours. We coordinate delivery timing to ensure your material is ready when our crew arrives.",
  },
  {
    question: "Can you match my existing hardwood flooring for repairs?",
    answer:
      "In many cases, yes. For common species like oak or maple, matching is straightforward. For exotic or discontinued species, we source the closest available match. For larger repairs, refinishing the entire room ensures a seamless, uniform appearance.",
  },
  {
    question: "Do you refinish existing hardwood floors?",
    answer:
      "Yes. We sand down to raw wood, apply your chosen stain, and finish with two to three coats of polyurethane. A refinish typically brings floors back to like-new condition for a fraction of replacement cost — as long as the floor has enough thickness remaining for sanding.",
  },
  {
    question: "What's the difference between solid and engineered hardwood?",
    answer:
      "Solid hardwood is milled from a single piece of wood and can be sanded and refinished many times over its lifetime. Engineered hardwood has a real wood veneer over a plywood core, making it more dimensionally stable and suitable for installation over concrete or in below-grade spaces like basements.",
  },
  {
    question: "Do you offer emergency flooring service for water damage?",
    answer:
      "Yes. For water damage situations where flooring needs immediate removal to prevent mold, we offer priority scheduling and can often respond same-day or next-day. Call us directly for urgent situations rather than submitting a standard quote request.",
  },
  {
    question: "What type of underlayment is best?",
    answer:
      "The best underlayment depends on your flooring type and subfloor. LVP often uses a thin foam pad. Laminate uses a thicker foam for sound dampening. Engineered hardwood may require a moisture barrier on concrete. We specify the correct underlayment in every estimate.",
  },
];

const serviceAreas = [
  { city: "Madison", driveTime: "Local", note: "Same-day available" },
  { city: "Huntsville", driveTime: "10-20 min", note: "Same-day available" },
  { city: "Decatur", driveTime: "25-35 min", note: "Serving this area" },
  { city: "Athens", driveTime: "20-30 min", note: "Serving this area" },
  { city: "Harvest", driveTime: "15-25 min", note: "Same-day available" },
  {
    city: "Owens Cross Roads",
    driveTime: "25-35 min",
    note: "Serving this area",
  },
  { city: "Hampton Cove", driveTime: "20-30 min", note: "Serving this area" },
  {
    city: "Redstone Arsenal",
    driveTime: "15-25 min",
    note: "Same-day available",
  },
];
---

<Layout
  title="Flooring Installation & Repair | Madison AL | Rittenworx"
  description="Professional hardwood, LVP, and laminate flooring installation and repair in Madison, Huntsville & North Alabama. Subfloor prep, refinishing & replacements. Free estimates."
>
  <!-- Premium Hero Section -->
  <section
    class="relative bg-blue-900 text-white pt-32 pb-24 flex items-center overflow-hidden"
  >
    <div class="absolute inset-0 z-0">
      <img
        src="/images/flooring.webp"
        alt="Hardwood Flooring Installation"
        class="w-full h-full object-cover opacity-20 scale-105 animate-[pulse_10s_ease-in-out_infinite_alternate]"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-blue-950 via-blue-900/90 to-blue-900/60"
      >
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 relative z-10 w-full">
      <div class="max-w-3xl">
        <nav
          class="text-blue-200 text-sm mb-6 flex items-center gap-2 font-medium tracking-wide"
        >
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="opacity-50">/</span>
          <a href="/services" class="hover:text-white transition-colors"
            >Services</a
          >
          <span class="opacity-50">/</span>
          <span class="text-orange-400">Flooring Installation & Repair</span>
        </nav>

        <div
          class="inline-block px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 mb-6 text-sm font-medium text-blue-100"
        >
          <span
            class="w-2 h-2 inline-block rounded-full bg-orange-400 mr-2 animate-pulse"
          ></span>
          Expert Flooring Installers
        </div>

        <h1
          class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight tracking-tight"
        >
          Flooring <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-orange-600"
            >Installation & Repair</span
          >
        </h1>

        <p
          class="text-xl md:text-2xl text-blue-100 mb-10 font-light leading-relaxed"
        >
          Hardwood, LVP, laminate, and engineered flooring installed with
          precision craftsmanship. Proper subfloor prep. Clean edges. Results
          that last.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="sms:2562210373"
            class="group bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 text-lg flex items-center justify-center gap-3 shadow-lg shadow-orange-500/30 hover:shadow-orange-500/50 hover:-translate-y-1 border border-orange-400/30"
          >
            <svg
              class="w-6 h-6 group-hover:scale-110 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
              ></path>
            </svg>
            Text A Photo For Instant Quote
          </a>
        </div>
      </div>
    </div>

    <!-- Decorative shape divider -->
    <div
      class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-10"
    >
      <svg
        class="relative block w-full h-[50px] md:h-[100px]"
        data-name="Layer 1"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1200 120"
        preserveAspectRatio="none"
      >
        <path
          d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.06,155.15,112.5,231.2,88.45,264.44,77.83,296.88,67.36,321.39,56.44Z"
          class="fill-orange-500"></path>
      </svg>
    </div>
  </section>

  <!-- Emergency Banner -->
  <section class="bg-orange-500 text-white py-4">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <svg
            class="w-8 h-8 flex-shrink-0"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <p class="font-bold">Emergency Water Damage Service</p>
            <p class="text-sm text-orange-100">
              Flooded floors? We offer priority scheduling to remove damaged
              flooring and prevent mold.
            </p>
          </div>
        </div>
        <a
          href="tel:+12562210373"
          class="bg-white text-orange-500 font-bold py-2 px-6 rounded-lg hover:bg-orange-50 transition-colors whitespace-nowrap"
        >
          Emergency Line
        </a>
      </div>
    </div>
  </section>

  <!-- SEO Introduction -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 prose prose-lg prose-blue">
      <h2
        class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-6 font-display tracking-tight"
      >
        Flooring Installation That's Done Right the First Time
      </h2>
      <p class="text-gray-700 text-lg leading-relaxed mb-6">
        New flooring is one of the highest-impact upgrades you can make to your
        home. It changes how every room looks and feels. But a beautiful floor
        starts with a properly prepared subfloor — and that's where most DIY and
        budget installs fail. At Rittenworx, we treat subfloor prep as seriously
        as the flooring itself. We inspect for squeaks, soft spots, levelness,
        and moisture before a single plank is laid, because we know that what's
        underneath determines how your floor looks and performs for the next
        20 years.
      </p>
      <p class="text-gray-700 text-lg leading-relaxed mb-6">
        Whether you're upgrading a single bedroom with luxury vinyl plank,
        installing solid hardwood throughout your main level, or refinishing
        dull, scratched floors back to their original beauty — we bring the same
        standard of workmanship to every job. Clean cuts at every wall. Proper
        expansion gaps. Tight seams. Transitions that look intentional, not
        afterthought. That's what separates a professional install from one that
        looks good for 6 months and starts failing in year two.
      </p>

      <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 mt-14">
        Choosing the Right Flooring for Your Home
      </h3>
      <p class="text-gray-700 text-lg leading-relaxed mb-6">
        Solid hardwood remains the gold standard for living rooms, dining rooms,
        and bedrooms — nothing else matches its warmth, longevity, or ability to
        be refinished multiple times over a lifetime. Engineered hardwood gives
        you the look of real wood with greater dimensional stability, making it
        the right call for basements, over concrete slabs, or over radiant heat
        systems. Luxury vinyl plank has become the dominant choice for
        kitchens, bathrooms, and whole-home installs where 100% waterproofing is
        non-negotiable — today's LVP products look nearly identical to real wood
        and outperform it in high-moisture areas.
      </p>
      <p class="text-gray-700 text-lg leading-relaxed mb-10">
        We don't push you toward any particular product. We walk you through the
        pros and cons of each option based on your specific rooms, lifestyle,
        budget, and long-term goals. Our job is to make sure you're happy with
        your flooring a decade from now, not just on installation day.
      </p>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-800 mb-4">What's Included</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Full-service flooring installation from subfloor to finished edge.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {
          includedServices.map((category) => (
            <div class="bg-gray-50 rounded-lg p-6 border border-gray-100">
              <h3 class="text-xl font-bold text-blue-900 mb-4 flex items-center gap-2">
                <svg
                  class="w-6 h-6 text-orange-500"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"
                  />
                </svg>
                {category.title}
              </h3>
              <ul class="space-y-2">
                {category.items.map((item) => (
                  <li class="flex items-start gap-2 text-gray-700">
                    <svg
                      class="w-4 h-4 text-green-500 mt-1 flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Flooring Comparison Guide -->
  <section class="py-12 bg-blue-50">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8 text-gray-800">
        Flooring Type Comparison Guide
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-lg shadow-sm">
          <thead>
            <tr class="bg-blue-900 text-white">
              <th class="px-4 py-3 text-left font-semibold">Type</th>
              <th class="px-4 py-3 text-left font-semibold">Lifespan</th>
              <th class="px-4 py-3 text-left font-semibold">Best For</th>
              <th class="px-4 py-3 text-left font-semibold">Waterproof</th>
              <th class="px-4 py-3 text-left font-semibold">Maintenance</th>
            </tr>
          </thead>
          <tbody>
            {
              flooringTypes.map((type, index) => (
                <tr class={index % 2 === 0 ? "bg-gray-50" : "bg-white"}>
                  <td class="px-4 py-3 font-semibold text-blue-900">
                    {type.name}
                  </td>
                  <td class="px-4 py-3 text-gray-700">{type.durability}</td>
                  <td class="px-4 py-3 text-gray-700">{type.best}</td>
                  <td class="px-4 py-3 text-gray-700">{type.waterproof}</td>
                  <td class="px-4 py-3 text-gray-600 text-sm">
                    {type.maintenance}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="text-center text-gray-500 text-sm mt-4">
        Not sure which flooring is right for your space? Text us a photo and
        we'll give you our honest recommendation.
      </p>
    </div>
  </section>

  <!-- Common Problems We Solve -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-800 mb-4">
          Flooring Problems We Fix
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          From water damage to squeaky subfloors, we diagnose and fix the root
          cause — not just the surface.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {
          commonProblems.map((item) => (
            <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-100">
              <div class="flex gap-4">
                <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg
                    class="w-5 h-5 text-red-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                    />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-800 mb-2">
                    {item.problem}
                  </h3>
                  <p class="text-gray-600 text-sm flex items-start gap-2">
                    <svg
                      class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {item.solution}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-800 mb-4">
          Our Installation Process
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          A systematic approach that delivers beautiful, long-lasting floors
          every single time.
        </p>
      </div>
      <div class="relative">
        <!-- Timeline line -->
        <div
          class="hidden md:block absolute left-1/2 transform -translate-x-1/2 h-full w-1 bg-blue-100"
        >
        </div>

        <div class="space-y-8 md:space-y-12">
          {
            processSteps.map((step, index) => (
              <div
                class={`flex flex-col md:flex-row gap-4 md:gap-8 ${index % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"}`}
              >
                <div
                  class={`flex-1 ${index % 2 === 0 ? "md:text-right" : "md:text-left"}`}
                >
                  <div
                    class={`bg-gray-50 rounded-lg p-6 border border-gray-100 ${index % 2 === 0 ? "md:mr-8" : "md:ml-8"}`}
                  >
                    <div class="flex items-center gap-3 mb-2">
